SERVER_PORT=8086

# Shared internal service secret — must match every other microservice
INTERNAL_API_KEY=

# JWT signing key — must match auth-service and api-gateway
JWT_SECRET=

# Exchange WebSocket connection
EXCHANGE_WS_HOST=wss://mock-exchange-host/ws
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# Frontend origin(s) allowed to connect via WebSocket (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173
